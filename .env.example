NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only login protection. Never prefix these values with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=
VERCEL=1
LOGIN_RATE_LIMIT_TRUSTED_PROXY_MODE=vercel-direct
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_DIGEST_SECRET=

# CI provisioning — used only by scripts/provision-ci-admin.ts in GitHub Actions.
# Do not set these locally; the provisioning script rejects non-CI environments.
CI_ADMIN_EMAIL=
CI_ADMIN_PASSWORD=
CI_ADMIN_STORE_NAME=
CI_ADMIN_STORE_SLUG=
CI_ADMIN_WHATSAPP_PHONE=
CI_ADMIN_ORIGIN_LABEL=
CI_ADMIN_ORIGIN_ADDRESS=
CI_ADMIN_ORIGIN_RAJAONGKIR_ID=
CI_ADMIN_ORIGIN_RAJAONGKIR_LEVEL=
